/* Estilo para enlaces tipo Wikipedia (azul, sin subrayado salvo hover) */
.wikilink {
    color: #0055a4;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
}
.wikilink:hover {
    border-bottom-color: #0055a4;
}

/* Bloque destacado (para frases clave con énfasis visual) */
.destacado {
    font-size: 1.2rem;
    font-weight: 500;
    color: #1a1a1a;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-left: 4px solid #0055a4;
    background-color: #f5f9ff;
    border-radius: 0 4px 4px 0;
    font-style: italic;
}

/* Citas (por si quieres darles un estilo distinto) */
blockquote {
    font-size: 1.1rem;
    color: #333;
    border-left: 4px solid #888;
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
}

/* Opcional: fecha y tags (para mantener consistencia) */
.meta-fecha {
    color: #555;
    font-size: 0.9rem;
    margin-top: -0.5rem;
}
.tags .tag {
    display: inline-block;
    background: #eee;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    color: #333;
    margin-right: 0.3rem;
}
